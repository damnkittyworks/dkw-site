<section class="hero card">
  <h1>Making AI and hard tech less mysterious.</h1>
  <p class="hero-tagline">
    AI, robotics, 3D printing, hydroponics, and useful little experiments
  </p>
  <hr class="hero-divider">
  <p>
    I write things down as I figure them out: the mistakes, reversals, parts lists, dead ends, and “oh, that’s all it was?” moments.
  </p>
  <p><a class="cta-link cta-button" href="/posts/">Read the posts →</a></p>
</section>


<section class="latest-thinking">
  <h2>Latest Posts</h2>
  {% set sortedPosts = collections.posts %}
  {% if collections.posts | length %}
    <ul class="thinking-list clean-list">
      {% for post in sortedPosts %}
        {% if loop.index <= 3 %}
          {% set updatedAt = post.data.updated or post.date %}
          <li>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            <p>{{ post | postSnippet(100) }}</p>
            <p class="meta-inline">
              Updated {{ updatedAt | prettyDate }} 
            </p>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  {% else %}
    <p>No posts yet. Check back soon.</p>
  {% endif %}
</section>

<section class="card">
