---
layout: base.njk
title: Posts
description: Notes, experiments, and explanations from Damn Kitty Works.
---
<section class="card">
  <h1>Posts</h1>
  <p>
    Notes, experiments, and explanations from the DKW small lab. Posts may be updated over time; major changes are noted inside the post.
  </p>
</section>

<section>
  {% set sortedPosts = collections.posts | sortPostsByLastUpdated(gitHistory) %}
  {% if collections.posts | length %}
    <ul class="post-list clean-list">
      {% for post in sortedPosts %}
        {% set updatedAt = post.data.updated or post.date %}
        <li class="post-list-item">
          <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
          <p>{{ post | postSnippet(100) or "No excerpt yet." }}</p>
          <p class="meta-inline">
            Published {{ post.date | prettyDate }} |
            Last updated {{ updatedAt | prettyDate }}
          </p>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>No posts yet.</p>
  {% endif %}
</section>
