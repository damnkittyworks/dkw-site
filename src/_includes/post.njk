---
layout: base.njk
---
{% set updatedAt = updated or date %}
{% set suppressPostMeta = draft or hideHistory %}

<article class="post-entry">
  <header class="post-header card">
    <h1>{{ title }}</h1>
    {% if not suppressPostMeta %}
      <p class="meta-inline">
        Published {{ date | prettyDate }} |
        Last updated {{ updatedAt | prettyDate }} 
      </p>
    {% endif %}
  </header>

  <div class="post-content card">
    {{ content | safe }}
  </div>


</article>
